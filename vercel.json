{
  "version": 2,
  "builds": [
    { "src": "server/api/index.js", "use": "@vercel/node" },
    { "src": "client/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/api/index.js" },
    { "src": "/(.*)", "dest": "/client/dist/$1" }
  ],
  "installCommand": "npm --prefix server install && npm --prefix client install",
  "buildCommand": "npm --prefix client run build"
}
